<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The bundle identifier, unique to your app -->
	<key>CFBundleIdentifier</key>
	<string>com.yourcompany.myapp</string>

	<!-- The bundle version, typically incremented with each release -->
	<key>CFBundleVersion</key>
	<string>0.0.1</string>

	<!-- The bundle short version string, shown as the version to users -->
	<key>CFBundleShortVersionString</key>
	<string>0.0.1</string>

	<!-- The display name of the app -->
	<key>CFBundleName</key>
	<string>MyApp</string>

	<!-- The executable name, must match the product name -->
	<key>CFBundleExecutable</key>
	<string>${EXECUTABLE_NAME}</string>

	<!-- Required device capabilities, like arm64 for newer iOS devices -->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>

	<!-- Supported interface orientations -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>

	<!-- Main storyboard file base name, leave this out since we are doing everything programmatically -->
	<!-- <key>UIMainStoryboardFile</key>
	<string>Main</string> -->

	<!-- Application launch screen, leave this out if you are configuring launch screen programmatically -->
	<!-- <key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string> -->

	<!-- Whether the app supports multiple windows on iPad -->
	<key>UIApplicationSupportsMultipleScenes</key>
	<false/>

</dict>
</plist>
